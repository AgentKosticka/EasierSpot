<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_approval_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/approval_title_new_device"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_primary_identity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/approval_identity_unknown"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_secondary_identity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/approval_identity_unknown"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_deny"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/approval_action_deny"
            android:layout_marginEnd="8dp"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/btn_approve"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/approval_action_approve" />

    </LinearLayout>

</LinearLayout>
